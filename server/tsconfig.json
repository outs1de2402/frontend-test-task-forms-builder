{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    // Дозволяє імпортувати без .js розширень
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true
  },
  "include": ["src/**/*"]
}
